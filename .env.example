# =============================================================
#  Tunisia Job Market Intelligence Platform
#  Fichier modèle — SAFE à committer dans Git
#  Copie en .env et remplace les valeurs par les tiennes
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tunisia_jobs
DB_USER=postgres
DB_PASSWORD=

DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/tunisia_jobs

# ── Anthropic (Claude AI) ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Ollama (Option 2 :  AI local — gratuit) ───────────────────────────────
# Ollama tourne en local, aucune clé API nécessaire
OLLAMA_HOST=
OLLAMA_MODEL=


# ── LinkedIn (optionnel) ──────────────────────────────────────
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=

# ── Scrapers ──────────────────────────────────────────────────
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=4.0
MAX_PAGES_EMPLOI_TN=20
MAX_PAGES_TANITJOBS=15
MAX_PAGES_REKRUTE=10

# ── Scheduler ─────────────────────────────────────────────────
SCRAPE_TIME=07:00

# ── Logs ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=scrape.log

# ── Exports ───────────────────────────────────────────────────
EXPORT_DIR=exports
